# =============================================================================
# Configuracao do Codex CLI
# =============================================================================
# ATENCAO: Este e um arquivo de exemplo. Nunca commite o arquivo .env real
# com valores reais para o repositorio.
#
# Como usar:
#   cp .env.example .env
#   # Edite o .env com seus valores reais
# =============================================================================

# -----------------------------------------------------------------------------
# OpenAI — Obrigatorio
# -----------------------------------------------------------------------------
# Sua chave de API da OpenAI.
# Obtenha em: https://platform.openai.com/api-keys
# Formato: sk-proj-... ou sk-...
OPENAI_API_KEY=sk-substitua-pela-sua-chave-aqui

# -----------------------------------------------------------------------------
# Configuracoes do Codex CLI — Opcionais
# -----------------------------------------------------------------------------

# Nivel de log do Codex CLI
# Valores: debug | info | warn | error
# Default: info
CODEX_LOG_LEVEL=info

# Modelo a usar para as interacoes
# Valores sugeridos: gpt-4o | gpt-4o-mini | o3-mini
# Default: gpt-4o (melhor qualidade)
# CODEX_MODEL=gpt-4o

# Modo de aprovacao padrao
# Valores: suggest | auto-edit | full-auto
# Default: suggest (mais seguro)
# CODEX_APPROVAL_MODE=suggest

# Timeout por operacao em segundos
# Default: 120 (2 minutos)
# CODEX_TIMEOUT=120

# Diretorio para salvar logs das sessoes headless
# Default: ./logs/codex
# CODEX_OUTPUT_DIR=./logs/codex
